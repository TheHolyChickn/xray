{
	"schemaVersion": 1,
	"id": "not-enough-racism",
	"version": "${version}",
	"name": "Not Enough Racism",
	"description": "Boih is the savior of skyblock.",
	"authors": [
		"TheHolyChickn"
	],
	"contact": {
		"homepage": "https://github.com/theholychickn",
		"sources": "https://github.com/theholychickn"
	},
	"license": "CC0-1.0",
	"icon": "assets/not-enough-racism/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"adapter": "kotlin",
				"value": "com.github.theholychickn.xray.ExampleMod"
			}
		],
		"client": [
			{
				"adapter": "kotlin",
				"value": "com.github.theholychickn.xray.client.NotEnoughRacismClient"
			}
		]
	},
	"mixins": [
		"not-enough-racism.mixins.json",
		{
			"config": "not-enough-racism.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.1.2",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}